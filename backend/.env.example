# StreamSub backend — environment configuration
# Copy this file to .env and edit as needed.
# Loaded automatically by uvicorn if you install python-dotenv:
#   pip install python-dotenv
# Or export variables in your shell before starting the server.

# ── ASR mode ──────────────────────────────────────────────────────────────
# fake  → cycling placeholder subtitles, no model download needed (default)
# real  → faster-whisper + deep-translator (requires extra pip installs)
ASR_MODE=fake

# ── faster-whisper model ───────────────────────────────────────────────────
# Size options: tiny (~75MB) | base (~145MB) | small (~470MB) | medium (~1.5GB) | large-v3 (~3GB)
# Larger = more accurate but slower. "base" is a good starting point.
WHISPER_MODEL=base

# Device: cpu | cuda
WHISPER_DEVICE=cpu

# Compute type: int8 (fastest CPU) | float16 (GPU) | float32 (most compatible)
WHISPER_COMPUTE=int8

# Language code for transcription (e.g. en, zh, ja, fr, auto for auto-detect)
WHISPER_LANGUAGE=en

# ── Translation ────────────────────────────────────────────────────────────
# Target language for deep-translator (GoogleTranslator language codes)
# Examples: zh-CN, ja, ko, fr, de, es, pt, ar
TRANSLATE_TARGET=zh-CN

# ── Audio pipeline ─────────────────────────────────────────────────────────
# Seconds of audio to buffer before running ASR (shorter = lower latency, more fragmented)
ASR_WINDOW_SECONDS=2.5

# Fake mode: seconds of audio between subtitle emissions
FAKE_SUBTITLE_INTERVAL=4.0
